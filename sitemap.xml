---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>monthly</changefreq>
    <priority>1.0</priority>
  </url>
  <url><loc>{{ site.url }}/books/</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/book-chapters/</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/journal-articles/</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/conference-papers/</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/magazine-articles/</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.url }}/maps/</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  {% for project in site.projects %}
  <url>
    <loc>{{ site.url }}{{ project.url | remove: '.html' }}</loc>
    {% if project.year %}<lastmod>{{ project.year }}-01-01</lastmod>{% endif %}
    <changefreq>yearly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}
</urlset>
