---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>{{ site.url }}/</loc><lastmod>{{ site.data.git_mtime }}</lastmod><changefreq>monthly</changefreq><priority>1.0</priority></url>
  {% for project in site.publications %}
  <url>
    <loc>{{ site.url }}{{ project.url | remove: '.html' }}</loc>
    <lastmod>{{ project.git_mtime }}</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}
</urlset>
